# API Настройки
PROXY_API_URL=https://api.proxyapi.ru/openai/v1/chat/completions
LLM_API_KEY=your_proxy_api_key_here
LLM_MAIN_MODEL=gpt-4o
LLM_ROUTER_MODEL=gpt-4o-mini

# Qdrant (Векторная БД)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ELK (Logstash)
LOGSTASH_HOST=logstash
LOGSTASH_PORT=50000

# Интеграция с Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=bot_service_account
JIRA_API_TOKEN=your_jira_token_here
JIRA_PROJECT_KEY=TDSK-SUP

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Настройки FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
